# ─── HTTP server ───────────────────────────────────────────────
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ─── Postgres (read-only, shared with bestduo_BE) ─────────────
# Railway 내부 네트워크: postgresql://<user>:<pw>@postgres.railway.internal:5432/railway
DATABASE_URL=postgresql://myuser:secret@localhost:5432/mydatabase
DATABASE_POOL_MIN=1
DATABASE_POOL_MAX=5
DATABASE_QUERY_TIMEOUT_MS=1500

# ─── Redis cache ──────────────────────────────────────────────
# Railway 내부 네트워크: redis://default:<pw>@redis.railway.internal:6379
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL_SECONDS=3600

# ─── Ollama / EXAONE ──────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=exaone3.5:2.4b-instruct-q4_K_M
OLLAMA_TIMEOUT_MS=15000
OLLAMA_NUM_PREDICT=256
OLLAMA_TEMPERATURE=0.2

# ─── Inbound auth (Spring BE → FastAPI) ───────────────────────
# Spring BE 가 X-Internal-Key 헤더로 이 값을 보내야 함
INTERNAL_API_KEY=change-me-in-railway

# ─── Observability ────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_RELEASE=bestduo-ai@local
PROMETHEUS_ENABLED=true
